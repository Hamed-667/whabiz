{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "cross-env PORT=3100 npm start",
      "startServerReadyPattern": "WhaBiz server running on http://localhost:3100",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:3100/",
        "http://localhost:3100/vendeur",
        "http://localhost:3100/admin.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": [
          "warn",
          {
            "minScore": 0.65
          }
        ],
        "categories:accessibility": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:best-practices": [
          "warn",
          {
            "minScore": 0.85
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.8
          }
        ]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
