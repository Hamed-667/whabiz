PORT=3000
JWT_SECRET=change-me
BCRYPT_ROUNDS=12

# Admin login
ADMIN_EMAIL=admin@whabiz.local
ADMIN_PASSWORD=Admin123!
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_COOKIE=whabiz_admin_session
ADMIN_SESSION_TTL_HOURS=12
ADMIN_COOKIE_SAMESITE=lax
ADMIN_COOKIE_SECURE=0
VENDEUR_SESSION_TTL_HOURS=24

# MySQL storage (set MYSQL_ENABLED=1 to force MySQL mode)
MYSQL_ENABLED=1
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=whabiz
MYSQL_TABLE=whabiz_store
MYSQL_SOURCE_OF_TRUTH=1
MYSQL_JSON_MIRROR_WRITES=0
MYSQL_SSL=0
MYSQL_SSL_REJECT_UNAUTHORIZED=1
MYSQL_SSL_CA=
MYSQL_BACKUP_AUTO=1
MYSQL_BACKUP_INTERVAL_HOURS=24
MYSQL_BACKUP_RETENTION_DAYS=14
MYSQL_RESTORE_TEST_AUTO=0
MYSQL_RESTORE_TEST_INTERVAL_HOURS=168
MYSQL_RESTORE_TEST_DB=whabiz_restore_test
MYSQL_PERSIST_QUEUE_MAX_WAIT_MS=5000
MYSQL_PERSIST_QUEUE_TIMEOUT_ALERT_INTERVAL_MS=300000
# Optional: full URL form (if set, it overrides host/port/user/password/database)
# MYSQL_URL=mysql://root:password@127.0.0.1:3306/whabiz

# Storage (images) - use cloud provider in production
STORAGE_PROVIDER=local
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=whabiz/products

# Optional email notifications
SMTP_USER=
SMTP_PASS=
OPS_ALERTS_ENABLED=1
OPS_ALERT_LEVELS=error,warning
OPS_ALERT_THROTTLE_MINUTES=30
OPS_ALERT_EMAIL_TO=
OPS_ALERT_EMAIL_FROM=
OPS_ALERT_WHATSAPP_PROVIDER=twilio
OPS_ALERT_WHATSAPP_FROM=whatsapp:+14155238886
OPS_ALERT_WHATSAPP_TO=
OPS_ALERT_WHATSAPP_WEBHOOK_URL=
OPS_ALERT_WHATSAPP_TOKEN=
OPS_ALERT_PHONE_COUNTRY_CODE=226
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Optional webhook signature secret
PAYMENT_WEBHOOK_SECRET=

# Security / auth hardening
API_RATE_LIMIT_MAX=900
LOGIN_RATE_LIMIT_MAX=8
ADMIN_LOGIN_RATE_LIMIT_MAX=5
SIGNUP_RATE_LIMIT_MAX=15
RECOVERY_RATE_LIMIT_MAX=5
AUTH_FAILURE_WINDOW_MS=900000
AUTH_FAILURE_LIMIT=5
AUTH_LOCK_MS=1200000
RECOVERY_MAX_ATTEMPTS=5
RECOVERY_CODE_SECRET=
RECOVERY_DEBUG_CODE=1
RECOVERY_WHATSAPP_LINK_ENABLED=1
RECOVERY_CODE_TTL_MINUTES=15
